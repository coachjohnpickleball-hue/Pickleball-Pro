+<script>
+/* === Disable unsafe regenerate actions ===
+   These actions previously rebuilt full schedules and could erase completed scores.
+   Keep only Generate Next Draft Round and Publish/Start until scheduler regeneration is fully refactored. */
+(function(){
+  function warn(){
+    try { toast('Regenerate is disabled to protect completed round history. Use Generate Next Draft Round for the next editable round.', 'err'); }
+    catch(e){ alert('Regenerate is disabled to protect completed round history.'); }
+    return false;
+  }
+  window.regenerateRemaining = warn;
+  window.regenerateSchedulePreview = warn;
+  window.pbRegenerateRound = warn;
+  window.rebuildUpcomingRounds = warn;
+  window.rebuildNextRound = warn;
+  function cleanUnsafeButtons(){
+    try {
+      document.querySelectorAll('button').forEach(function(btn){
+        var txt=(btn.textContent||'').trim();
+        var onclick=(btn.getAttribute('onclick')||'');
+        if(/Regenerate Remaining|Regenerate Draft Rounds|Regenerate Preview|Regenerate Round|Rebuild Next Round/.test(txt) || /regenerateRemaining|regenerateSchedulePreview|pbRegenerateRound|rebuildUpcomingRounds|rebuildNextRound/.test(onclick)){
+          btn.remove();
+        }
+      });
+    } catch(e){}
+  }
+  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', cleanUnsafeButtons); else cleanUnsafeButtons();
+  setInterval(cleanUnsafeButtons, 1000);
+})();
+</script>
+
 </body>
 </html>
